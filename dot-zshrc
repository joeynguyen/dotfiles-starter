# Zinit-optimized zsh configuration

# Enable profiling (comment out after testing)
# zmodload zsh/zprof

# enables Ghosty shell integration with Zsh
# This doesn't do anything in other Terminal apps because the GHOSTTY_RESOURCES_DIR env won't exist
if [[ -n "${GHOSTTY_RESOURCES_DIR}" ]]; then
    builtin source "${GHOSTTY_RESOURCES_DIR}/shell-integration/zsh/ghostty-integration"
fi

DOTFILES_GIT_DIR=~/git/dotfiles

#####################################
### History Configuration - START ###
#####################################

# Uncomment the following line if you want to change the command execution time
# stamp shown in the history command output.
# The optional three formats: "mm/dd/yyyy"|"dd.mm.yyyy"|"yyyy-mm-dd"
# HIST_STAMPS="mm/dd/yyyy"
# history file location
HISTFILE="$HOME/.zsh_history"
# maximum number of history entries in memory
HISTSIZE=100000
# maximum number of history entries saved to the history file
SAVEHIST=100000
# don't share history between terminal windows
unsetopt share_history
# Append to ~/.zsh_history instead of overwriting it -- this stops terminals
# from overwriting one another's histories.
setopt INC_APPEND_HISTORY_TIME
# Setting the extended_history records the timestamp of each command in HISTFILE (along with the actual command)
setopt EXTENDED_HISTORY
# ensures all previous lines matching the current command is removed from history before the current command is saved
setopt HIST_IGNORE_ALL_DUPS
# don't store any commands that begin with a space into history ('export'-ing env secrets into CLI)
setopt HIST_IGNORE_SPACE
# trim extra whitespace from each entry
setopt HIST_REDUCE_BLANKS

###################################
### History Configuration - END ###
###################################

##################################
### brew Configuration - START ###
##################################

# Initialize Homebrew if installed
if [[ -x /opt/homebrew/bin/brew ]]; then
    # MacOS
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
    # Linux (tested on Ubuntu Server 24.04 LTS)
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# enable tab completions for apps installed by Homebrew (if the app has defined them)
if [[ -n "${HOMEBREW_PREFIX:-}" ]]; then
    # fpath is where Zsh looks for autoloadable functions and completion definitions. Adding Homebrew’s
    # site-functions directory lets 'compinit' discover the completion scripts Homebrew installed.
    fpath=("$HOMEBREW_PREFIX/share/zsh/site-functions" $fpath)
fi

################################
### brew Configuration - END ###
################################


############################################
### Zinit Installation and Setup - START ###
############################################

# Zinit is a plugin manager for Zsh designed to speed up load times. It's faster than OhMyZsh
# because it doesn't have all of the bells and whistles that a Zsh framework like OhMyZsh does.
# However, it does support using OhMyZsh plugins - https://github.com/ohmyzsh/ohmyzsh/wiki/plugins.

ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"

# Download Zinit if it hasn't been installed
if [[ ! -d "$ZINIT_HOME" ]]; then
    mkdir -p "$(dirname $ZINIT_HOME)"
    git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi

# Load Zinit
skip_global_compinit=1
source "${ZINIT_HOME}/zinit.zsh"

# Completion performance optimizations
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path ~/.zsh/cache
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' accept-exact '*(N)'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath'
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'ls --color $realpath'

### Zinit Plugin Loading ###

# OhMyZsh plugins - https://github.com/ohmyzsh/ohmyzsh/wiki/plugins

# example of how you can install and use them (if you uncomment the lines)

# Load essential libraries that other plugins may depend on
# zinit snippet OMZL::clipboard.zsh
# zinit snippet OMZL::completion.zsh
# zinit snippet OMZL::history.zsh
# zinit snippet OMZL::key-bindings.zsh

# Load prompt-critical plugins immediately
zinit light "Aloxaf/fzf-tab"
zinit light "zsh-users/zsh-autosuggestions"
# zsh-completions (https://github.com/zsh-users/zsh-completions) seems useful on Linux but not so much on MacOS for our setup
# zinit light "zsh-users/zsh-completions"
# uncomment the plugin below if you like Vim
# zinit light "jeffreytse/zsh-vi-mode"

### zsh-vi-mode fixes - START ###
# Fix for not working with built-in Alt+. "append last argument" feature
# uncomment lines below if you decide to use zsh-vi-mode
# function append-last-word { ((++CURSOR)); zle insert-last-word; }
# zle -N append-last-word
# bindkey -M vicmd '\e.' append-last-word
# bindkey -M viins '\e.' insert-last-word
### zsh-vi-mode fixes - END ###

# Turbo mode in Zinit means loading Zsh plugins and snippets asynchronously (in the background)
# after the initial command prompt is already displayed.
# Load these plugins with Turbo mode for faster startup.
# Uncomment the ones you find useful after learning more about them.
zinit wait lucid for \
    OMZP::colored-man-pages
    # OMZP::extract \
    # OMZP::urltools \


# Make zsh autocomplete with up/down arrow history search
# Combined the first two answers from this link - https://unix.stackexchange.com/questions/621606/zsh-completion-with-up-and-down-arrows
autoload -Uz history-search-end
zle -N history-beginning-search-backward-end history-search-end
zle -N history-beginning-search-forward-end history-search-end
bindkey '^[[A' history-beginning-search-backward-end
bindkey '^[[B' history-beginning-search-forward-end

# replay all cached completions
zinit cdreplay -q

# Zinit conditional plugin loading (only if commands exist) using 'has'

# https://github.com/ohmyzsh/ohmyzsh/tree/master/plugins/asdf
# This plugin puts the location of where asdf installs packages into your PATH
zinit wait lucid has'asdf' for \
    OMZP::asdf

# https://github.com/ohmyzsh/ohmyzsh/blob/master/plugins/fzf
# This plugin finds fzf based on where it's been installed and enables its fuzzy auto-completion and key bindings
zinit wait lucid has'fzf' for \
    OMZP::fzf

# https://github.com/ohmyzsh/ohmyzsh/tree/master/plugins/zoxide
# if defined, ZOXIDE_CMD_OVERRIDE passes the value into the --cmd flag of 'zoxide init'.
# This allows you to replace the built-in 'cd' with the zoxide 'z' command.
ZOXIDE_CMD_OVERRIDE=cd
zinit wait lucid has'zoxide' for \
    OMZP::zoxide

_fix-omz-plugin() {
    [[ -f ./._zinit/teleid ]] || return 1

    local teleid pluginid file
    teleid="$(<./._zinit/teleid)"

    for pluginid in "${teleid#OMZ::plugins/}" "${teleid#OMZP::}"; do
        [[ "$pluginid" != "$teleid" ]] && break
    done

    [[ "$pluginid" != "$teleid" ]] || return 1

    print "Fixing $teleid..."

    git clone --quiet --no-checkout --depth=1 --filter=tree:0 https://github.com/ohmyzsh/ohmyzsh || return 1

    (
        cd ./ohmyzsh || exit 1
        git sparse-checkout set --no-cone "/plugins/$pluginid" &&
        git checkout --quiet
    ) || return 1

    for file in ./ohmyzsh/plugins/$pluginid/*~(.gitignore|*.plugin.zsh)(D); do
        print "Copying ${file:t}..."
        cp -R "$file" "./${file:t}"
    done

    rm -rf ./ohmyzsh
}

# Load syntax highlighting last and with turbo
zinit wait lucid for \
    "zsh-users/zsh-syntax-highlighting"

# fix Zinit integration with installing some oh-my-zsh plugins
# uncomment the line below if you want to use the 'wd' plugin
# zinit wait lucid atpull"%atclone" atclone"_fix-omz-plugin" for OMZ::plugins/wd

##########################################
### Zinit Installation and Setup - END ###
##########################################

### Load environment variables ###
source "${DOTFILES_GIT_DIR}/env-variables"
# refer to README.md on creating this secrets file and, IMPORTANTLY!, ensure it isn't committed to your dotfiles repo
[[ -f ~/.my-env-secrets ]] && source ~/.my-env-secrets

### Load aliases and functions ###
for f in ${DOTFILES_GIT_DIR}/aliases-and-functions/*(N.); do
  source "$f"
done

### Load keybindings (this should go after shell-aliases because keybindings may reference defined functions/aliases) ###
source "${DOTFILES_GIT_DIR}/keybindings"

# start OhMyPosh - https://ohmyposh.dev/
if [[ -f "$HOME/.config/ohmyposh/ohmyposh.toml" ]]; then
  _omp_cache="$HOME/.cache/ohmyposh-init.zsh"
  if [[ ! -f "$_omp_cache" || "$HOME/.config/ohmyposh/ohmyposh.toml" -nt "$_omp_cache" ]]; then
    mkdir -p "$HOME/.cache"
    oh-my-posh init zsh --config "$HOME/.config/ohmyposh/ohmyposh.toml" > "$_omp_cache"
  fi
  source "$_omp_cache"
  unset _omp_cache
fi

