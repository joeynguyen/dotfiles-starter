# RELOADING THE CONFIGURATION
# This configuration file can be reloaded at runtime by pressing CMD+SHIFT+, (macOS) or CTRL+SHIFT+, (Linux).
# This is the default keybinding, but it is possible to define your own via the reload_config action (see Keybindings section at the bottom).

# Comments start with a `#` and are only valid on their own line.

# The syntax is "key = value". The whitespace around the equal sign doesn't matter.
# Values can be quoted or unquoted. font-family = "JetBrains Mono" is the same as font-family = JetBrains Mono.
# Empty values reset the configuration to the default value


### APPEARANCE ###

# https://ghostty.org/docs/config/reference

font-size = 16

# See list of recommended fonts in docs/ folder
# download JetBrains Mono from https://www.jetbrains.com/lp/mono and uncomment the line below
# font-family = JetBrains Mono

# TEST LIGATURES (from Fira Code - https://github.com/tonsky/FiraCode/blob/e50b177465f32b2f439098c4fcf7451cf70adc6b/README.md#whats-in-the-box):
# -- Arithmetic: ++ -- /= && || ||=
# -- Scope: -> => :: __
# -- Equality: == === != !==
# -- Comparison: <= >= <=>
# -- JavaScript: ?. !! **
# -- HTML: <!-- </> </ />
# -- Java: <> <~>
# -- Go: :=
# -- Kotlin: ?. ?: ..
# -- Others: <=> <<= >>=
# -- Arrows: --> <- -> ~~>

# turn off ligatures
# font-feature = -calt, -liga, -dlig

# Every configuration key is a valid CLI flag when launching Ghostty from the command-line. For example, the background key can be set with ghostty --background=282c34. Or the font-family key can be set with ghostty --font-family="JetBrains Mono".

# run "ghostty +list-themes" in your terminal to preview other theme options
theme = Dracula+
# other recommended ones to try
# theme = Atelier Sulphurpool
# theme = Dracula
# theme = GitHub Dark Default
# theme = Tomorrow Night Eighties
# theme = Ultra Dark
# theme = Ultra Violent

# When the cursor is located over text, invert the color of the foreground and background of the cursor.
# This setting makes it easy to distinguish where the cursor is on most themes because some of them
# don't do a good job of setting the cursor color values.
cursor-invert-fg-bg = true

# windows
window-padding-color = background
window-decoration = false
window-padding-x = 2
window-padding-y = 0
window-padding-balance = true

# OS-specific settings

## MacOS
macos-option-as-alt = true
# for users who dislike how MacOS natively implements Full Screen functionality
macos-non-native-fullscreen = true

# options: native | tabs | transparent | hidden
# 'tabs' provides the most vertical window real estate, but choose what you like
macos-titlebar-style = tabs



### KEYBINDINGS ###

# https://ghostty.org/docs/config/keybind

# The CLI command list-keybinds can be used to list all the available keybinds for Ghostty. You can run this to see the default ones:
# ghostty +list-keybinds --default

# uncomment the below 'keybind = ...' lines if you want to change the default keybindings
# Command+Shift+R - update Ghostty using the updated settings in this file
# keybind = super+shift+r=reload_config
# Command+Shift+F - toggle full screen
# keybind = super+shift+f=toggle_fullscreen

